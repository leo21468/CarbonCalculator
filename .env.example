# FastAPI 服务配置
HOST=0.0.0.0
PORT=8000

# CORS 配置（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# 碳价配置（元/吨CO2e）
CARBON_PRICE_PER_TON=100.0

# 数据库路径（默认项目根目录）
DB_PATH=./carbon_data.db

# ── 企业对接（可选）──
# 碳核算成功后向贵司系统 POST JSON（见 docs/ENTERPRISE_INTEGRATION.md）
# ERP_CARBON_RESULT_WEBHOOK_URL=https://your-erp.example.com/hooks/carbon-result
